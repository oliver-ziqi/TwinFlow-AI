# ---------- Gemini ----------
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
LLM_MODEL=gemini-2.0-flash-free
AIHUBMIX_API_KEY=YOUR_AIHUBMIX_API_KEY
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
TEMPERATURE=0.2

# ---------- Postgres ----------
PG_DSN=dbname=jaamsim user=ai_user password=YOUR_DB_PASSWORD host=localhost port=5432

# ---------- Influx ----------
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=YOUR_INFLUX_TOKEN
INFLUX_ORG=my-org
INFLUX_BUCKET=queue_data

# (for watcher) alert bucket/measurement/field
ALERT_BUCKET=alerts
ALERT_MEASUREMENT=stationary_alert
ALERT_FIELD=message
POLL_SEC=10
CURSOR_FILE=alert_cursor.txt

# ---------- Kafka ----------
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_ALERTS=alert-events
KAFKA_TOPIC_RESULTS=analysis-results
KAFKA_GROUP_ID=monitor-task
